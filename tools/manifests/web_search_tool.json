{
  "id": "web_search",
  "name": "Web Search",
  "description": "Searches the web and returns ranked results. Mock implementation only.",
  "category": "Search",
  "version": "1.0.0",
  "permission_level": "read",
  "permissions_required": ["network.search"],
  "input_schema": {
    "type": "object",
    "properties": {
      "query": { "type": "string" },
      "max_results": { "type": "integer", "default": 5 }
    },
    "required": ["query"]
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "results": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "url": { "type": "string" },
            "snippet": { "type": "string" }
          }
        }
      }
    }
  },
  "mock_implementation_notes": "Return canned search results from datasets/mock_search_results.json."
}
