{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ToolCallTrace",
  "description": "Schema for agent execution tool-call traces",
  "type": "object",
  "required": ["agent_id", "run_id", "steps"],
  "properties": {
    "agent_id": { "type": "string" },
    "run_id": { "type": "string" },
    "status": { "type": "string" },
    "started_at": { "type": "string", "format": "date-time" },
    "completed_at": { "type": "string", "format": "date-time" },
    "user_request": { "type": "string" },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["step", "action"],
        "properties": {
          "step": { "type": "integer" },
          "action": { "type": "string" },
          "details": { "type": "string" },
          "tool": { "type": "string" },
          "input": { "type": "object" },
          "output_summary": { "type": "string" }
        }
      }
    },
    "final_output": { "type": "object" }
  }
}
