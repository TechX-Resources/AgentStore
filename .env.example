# AgentStore Environment Variables
# Copy this file to .env and fill in values as needed.
# Do NOT commit real API keys or secrets.

# Backend
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
DEBUG=true

# Frontend (Vite)
VITE_API_BASE_URL=http://127.0.0.1:8000

# Storage paths (relative to backend/)
STORAGE_PATH=app/storage/data

# LLM / Agent layer (placeholders — not used in skeleton)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# MCP integration (future — do not connect yet)
# MCP_SERVER_URL=
